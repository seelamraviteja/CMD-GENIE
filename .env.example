# Copy to `.env` and tweak. docker compose reads it automatically.

# Which pulled Ollama model to use (run `ollama list` to see yours).
OLLAMA_MODEL=gemma3:4b

# Port the web app is published on.
PORT=8090

# Where Ollama is reachable from inside the container.
# OLLAMA_HOST=http://host.docker.internal:11434

# Context window. Bump if your cheat-sheet grows large.
# OLLAMA_NUM_CTX=16384
